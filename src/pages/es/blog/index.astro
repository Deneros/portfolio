---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalePath, getDateLocale } from '@/i18n/utils';

const lang = 'es';
const t = useTranslations(lang);

const posts = (await getCollection('blog_es'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title={t('blog.title')} description={t('blog.description')} lang={lang}>
  <section class="section-container max-w-3xl">
    <h1 class="section-title">{t('blog.title')}</h1>
    <p class="section-subtitle">{t('blog.subtitle')}</p>

    {posts.length === 0 ? (
      <div class="card text-center py-12">
        <p class="text-surface-400 text-lg mb-2">{t('blog.empty')}</p>
        <p class="text-surface-500 text-sm">{t('blog.emptySubtitle')}</p>
      </div>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => {
          const slug = post.data.slug || post.id.replace(`${lang}/`, '');
          const formattedDate = new Date(post.data.date).toLocaleDateString(getDateLocale(lang), { year: 'numeric', month: 'long', day: 'numeric' });
          return (
            <a href={getLocalePath(lang, `/blog/${slug}`)} class="card block group hover:-translate-y-0.5">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag) => (<span class="badge">{tag}</span>))}
              </div>
              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-primary-400 transition-colors">{post.data.title}</h2>
              <p class="text-surface-400 text-sm mb-4 line-clamp-2">{post.data.description}</p>
              <div class="flex items-center gap-4 text-xs text-surface-500">
                <time datetime={post.data.date}>{formattedDate}</time>
                {post.data.readTime && (<><span>·</span><span>{post.data.readTime} {t('blog.readTime')}</span></>)}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Layout>
