---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { site, stats } from '@/config';
import { useTranslations, getLocalePath } from '@/i18n/utils';

const lang = 'es';
const t = useTranslations(lang);

const projects = (await getCollection('projects_es'))
  
  .sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((p) => p.data.featured);
---

<Layout title={t('nav.home')} lang={lang}>
  <!-- Hero -->
  <section class="section-container min-h-[90vh] flex flex-col justify-center relative">
    <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full opacity-[0.03] pointer-events-none" style="background: radial-gradient(circle, #e8a741, transparent 70%);"></div>

    <div class="max-w-2xl">
      <p class="section-label animate-fade-up">// {site.title.toLowerCase()}</p>

      <h1 class="heading-display text-5xl sm:text-6xl md:text-7xl mb-8 animate-fade-up delay-1">
        {t('hero.greeting')}<br/>
        <span class="gradient-text">{site.name}</span>
      </h1>

      <p class="text-base md:text-lg text-[#606070] leading-relaxed mb-10 max-w-lg animate-fade-up delay-2">
        {t('hero.description')}
        <span class="text-white"> {t('hero.backend')}</span>,
        <span class="text-white"> {t('hero.devops')}</span> {lang === 'es' ? 'y' : 'and'}
        <span class="text-white"> {t('hero.microservices')}</span>.
        {t('hero.experience')}
      </p>

      <div class="flex flex-wrap gap-4 animate-fade-up delay-3">
        <a href={getLocalePath(lang, '/projects')} class="btn-primary">
          {t('hero.cta')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={getLocalePath(lang, '/contact')} class="btn-outline">{t('hero.contact')}</a>
      </div>

      <div class="flex items-center gap-10 mt-16 pt-8 animate-fade-up delay-4" style="border-top: 1px solid rgba(255,255,255,0.04);">
        <div>
          <p class="text-2xl font-bold text-white" style="font-family: 'Instrument Serif', serif;">{stats.projects}</p>
          <p class="text-[#404050] text-xs tracking-wide mt-1">{t('stats.projects')}</p>
        </div>
        <div class="w-px h-8" style="background: rgba(255,255,255,0.06);"></div>
        <div>
          <p class="text-2xl font-bold text-white" style="font-family: 'Instrument Serif', serif;">{stats.years}</p>
          <p class="text-[#404050] text-xs tracking-wide mt-1">{t('stats.years')}</p>
        </div>
        <div class="w-px h-8" style="background: rgba(255,255,255,0.06);"></div>
        <div>
          <p class="text-2xl font-bold text-white" style="font-family: 'Instrument Serif', serif;">{stats.companies}</p>
          <p class="text-[#404050] text-xs tracking-wide mt-1">{t('stats.companies')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section-container section-divider">
    <p class="section-label">{t('stack.label')}</p>
    <h2 class="section-title">{t('stack.title')}</h2>
    <p class="section-subtitle">{t('stack.subtitle')}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { icon: '&#9632;', color: '#60a5fa', name: t('stack.backend'), items: ['Spring Boot', 'Django', 'Laravel', 'FastAPI', 'Express', 'Java', 'Python', 'PHP'] },
        { icon: '&#9670;', color: '#34d399', name: t('stack.frontend'), items: ['React', 'Next.js', 'Astro', 'TypeScript', 'TailwindCSS', 'Flutter'] },
        { icon: '&#9733;', color: '#c084fc', name: t('stack.ai'), items: ['RAG', 'pgvector', 'Ollama', 'OpenAI', 'Celery', 'ML Pipelines'] },
        { icon: '&#9679;', color: '#fb923c', name: t('stack.databases'), items: ['PostgreSQL', 'MySQL', 'Redis', 'Prisma', 'Flyway'] },
        { icon: '&#9651;', color: '#22d3ee', name: t('stack.devops'), items: ['Docker', 'Kubernetes', 'Dokploy', 'Jenkins', 'GitHub Actions', 'CI/CD', 'SonarQube'] },
        { icon: '&#9674;', color: '#f472b6', name: t('stack.architecture'), items: ['Microservices', 'DDD', 'REST', 'WebSockets', 'Eureka', 'API Gateway'] },
      ].map((cat) => (
        <div class="card">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-sm" style={`color: ${cat.color}`} set:html={cat.icon}></span>
            <h3 class="text-white text-sm font-semibold">{cat.name}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {cat.items.map((item) => (
              <span class="tech-pill">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section-container section-divider">
    <div class="flex items-end justify-between mb-14">
      <div>
        <p class="section-label">{t('featured.label')}</p>
        <h2 class="section-title">{t('featured.title')}</h2>
        <p class="text-[#606070] text-base mt-1">{t('featured.subtitle')}</p>
      </div>
      <a href={getLocalePath(lang, '/projects')} class="hidden sm:inline-flex btn-outline text-xs">
        {t('featured.viewAll')}
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {featuredProjects.map((project) => {
        const slug = project.data.slug || project.id.replace(`${lang}/`, '');
        return (
          <a href={getLocalePath(lang, `/projects/${slug}`)} class="card group cursor-pointer">
            {project.data.image && (
              <div class="mb-4 -mx-6 -mt-6 overflow-hidden rounded-t-xl">
                <img src={project.data.image} alt={project.data.title} class="w-full h-40 object-cover object-top opacity-80 group-hover:opacity-100 transition-opacity duration-500" loading="lazy" />
              </div>
            )}
            <div class="flex items-start justify-between mb-5">
              <span class={`badge-${project.data.status}`}>{project.data.statusLabel}</span>
              <svg class="w-4 h-4 text-[#2a2a35] group-hover:text-amber-400/60 transition-colors duration-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-amber-400 transition-colors duration-300" style="font-family: 'Instrument Serif', serif; font-size: 1.35rem;">{project.data.title}</h3>
            <p class="text-[#505060] text-sm mb-5 leading-relaxed line-clamp-2">{project.data.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.data.stack.slice(0, 5).map((tech: string) => (
                <span class="tech-pill">{tech}</span>
              ))}
              {project.data.stack.length > 5 && (
                <span class="text-[10px] text-[#3a3a45] px-2 py-1">+{project.data.stack.length - 5}</span>
              )}
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-6 text-center sm:hidden">
      <a href={getLocalePath(lang, '/projects')} class="btn-outline text-xs">{t('featured.viewAllMobile')}</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-container section-divider text-center">
    <p class="section-label">{t('cta.label')}</p>
    <h2 class="heading-display text-3xl md:text-4xl mb-4">{t('cta.title')}</h2>
    <p class="text-[#505060] text-base mb-10 max-w-md mx-auto">{t('cta.subtitle')}</p>
    <a href={getLocalePath(lang, '/contact')} class="btn-primary">
      {t('cta.button')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </section>
</Layout>

<script>
  localStorage.setItem('lang', 'es');
</script>
