---
import Layout from '@layouts/Layout.astro';
import { social } from '@/config';
import { useTranslations } from '@/i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<Layout title={t('contact.title')} description={t('contact.description')} lang={lang}>
  <section class="section-container max-w-4xl">
    <p class="section-label">// contact</p>
    <h1 class="section-title">{t('contact.title')}</h1>
    <p class="section-subtitle">{t('contact.subtitle')}</p>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
      <div class="md:col-span-2 space-y-4">
        <a href={`mailto:${social.email}`} class="card flex items-center gap-4 group">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(232,167,65,0.06); border: 1px solid rgba(232,167,65,0.1);">
            <svg class="w-4 h-4 text-amber-400/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <div><p class="text-white text-sm font-medium">Email</p><p class="text-[#505060] text-xs">{social.email}</p></div>
        </a>
        <a href={social.linkedin} target="_blank" rel="noopener" class="card flex items-center gap-4 group">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(96,165,250,0.06); border: 1px solid rgba(96,165,250,0.1);">
            <svg class="w-4 h-4 text-blue-400/70" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </div>
          <div><p class="text-white text-sm font-medium">LinkedIn</p><p class="text-[#505060] text-xs">Nicolás Vélez Muñoz</p></div>
        </a>
        <a href={social.github} target="_blank" rel="noopener" class="card flex items-center gap-4 group">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
            <svg class="w-4 h-4 text-[#606070]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <div><p class="text-white text-sm font-medium">GitHub</p><p class="text-[#505060] text-xs">@Deneros</p></div>
        </a>
      </div>

      <div class="md:col-span-3">
        <form class="space-y-5" action="https://formspree.io/f/mykbayep" method="POST">
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <div>
            <label for="name" class="block text-xs font-medium text-[#606070] mb-2 tracking-wide">{t('contact.name')}</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg text-sm text-white placeholder:text-[#303040] outline-none transition-colors duration-300" style="background: rgba(14,14,22,0.8); border: 1px solid rgba(255,255,255,0.04);" onfocus="this.style.borderColor='rgba(232,167,65,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.04)'" placeholder={t('contact.namePlaceholder')} />
          </div>
          <div>
            <label for="email" class="block text-xs font-medium text-[#606070] mb-2 tracking-wide">{t('contact.email')}</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg text-sm text-white placeholder:text-[#303040] outline-none transition-colors duration-300" style="background: rgba(14,14,22,0.8); border: 1px solid rgba(255,255,255,0.04);" onfocus="this.style.borderColor='rgba(232,167,65,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.04)'" placeholder={t('contact.emailPlaceholder')} />
          </div>
          <div>
            <label for="message" class="block text-xs font-medium text-[#606070] mb-2 tracking-wide">{t('contact.message')}</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg text-sm text-white placeholder:text-[#303040] outline-none transition-colors duration-300 resize-none" style="background: rgba(14,14,22,0.8); border: 1px solid rgba(255,255,255,0.04);" onfocus="this.style.borderColor='rgba(232,167,65,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.04)'" placeholder={t('contact.messagePlaceholder')}></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">
            {t('contact.send')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
