---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Blog" description="Artículos sobre AI, arquitectura de software, DevOps y patrones de diseño">
  <section class="section-container max-w-3xl">
    <h1 class="section-title">Blog</h1>
    <p class="section-subtitle">
      Escribo sobre lo que aprendo construyendo software — AI, arquitectura, DevOps y patrones.
    </p>

    {posts.length === 0 ? (
      <div class="card text-center py-12">
        <p class="text-surface-400 text-lg mb-2">Próximamente</p>
        <p class="text-surface-500 text-sm">Estoy preparando los primeros artículos. Vuelve pronto.</p>
      </div>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <a href={`/blog/${post.id}`} class="card block group hover:-translate-y-0.5">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag) => (
                  <span class="badge">{tag}</span>
                ))}
              </div>

              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-primary-400 transition-colors">
                {post.data.title}
              </h2>

              <p class="text-surface-400 text-sm mb-4 line-clamp-2">
                {post.data.description}
              </p>

              <div class="flex items-center gap-4 text-xs text-surface-500">
                <time datetime={post.data.date}>{formattedDate}</time>
                {post.data.readTime && (
                  <>
                    <span>·</span>
                    <span>{post.data.readTime} de lectura</span>
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Layout>
