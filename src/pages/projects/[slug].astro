---
import Layout from '@layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const gallery = project.data.gallery || (project.data.image ? [project.data.image] : []);
---

<Layout title={project.data.title} description={project.data.description}>
  <article class="section-container max-w-3xl">
    <a href="/projects" class="inline-flex items-center gap-2 text-[#404050] hover:text-amber-400 transition-colors duration-300 mb-10 text-xs tracking-wide">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a proyectos
    </a>

    <header class="mb-14">
      <div class="flex flex-wrap items-center gap-2 mb-5">
        <span class={`badge-${project.data.status}`}>{project.data.statusLabel}</span>
        {project.data.tags.map((tag: string) => (
          <span class="badge">{tag}</span>
        ))}
      </div>

      <h1 class="heading-display text-4xl md:text-5xl mb-5 animate-fade-up">
        {project.data.title}
      </h1>

      <p class="text-[#606070] text-lg leading-relaxed mb-8 animate-fade-up delay-1">
        {project.data.longDescription || project.data.description}
      </p>

      <div class="flex flex-wrap gap-1.5 mb-8 animate-fade-up delay-2">
        {project.data.stack.map((tech: string) => (
          <span class="tech-pill">{tech}</span>
        ))}
      </div>

      {/* ── Screenshot Gallery ── */}
      {gallery.length > 0 && (
        <div class="animate-fade-up delay-3">
          {gallery.length === 1 ? (
            /* Single image — simple hero */
            <div class="gallery-frame cursor-pointer" data-gallery-open="0">
              <img
                src={gallery[0]}
                alt={project.data.title}
                class="w-full"
                loading="lazy"
              />
            </div>
          ) : (
            /* Multi-image showcase */
            <div class="gallery-showcase">
              {/* Hero — first image large */}
              <div class="gallery-frame gallery-hero cursor-pointer" data-gallery-open="0">
                <div class="gallery-number">01</div>
                <img
                  src={gallery[0]}
                  alt={`${project.data.title} — Vista principal`}
                  class="w-full"
                  loading="lazy"
                />
              </div>

              {/* Remaining images in grid */}
              <div class={`gallery-grid gallery-grid-${Math.min(gallery.length - 1, 3)}`}>
                {gallery.slice(1).map((src: string, i: number) => (
                  <div
                    class="gallery-frame cursor-pointer"
                    data-gallery-open={String(i + 1)}
                    style={`animation-delay: ${0.1 * (i + 1)}s`}
                  >
                    <div class="gallery-number">{String(i + 2).padStart(2, '0')}</div>
                    <img
                      src={src}
                      alt={`${project.data.title} — Captura ${i + 2}`}
                      class="w-full"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {(project.data.github || project.data.demo) && (
        <div class="flex gap-3 mt-8 animate-fade-up delay-4">
          {project.data.github && (
            <a href={project.data.github} target="_blank" rel="noopener" class="btn-outline text-xs">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          )}
          {project.data.demo && (
            <a href={project.data.demo} target="_blank" rel="noopener" class="btn-primary text-xs">
              Live Demo
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      )}
    </header>

    <div class="prose-custom">
      <Content />
    </div>
  </article>

  {/* ── Lightbox Overlay ── */}
  {gallery.length > 0 && (
    <div id="lightbox" class="lightbox" aria-hidden="true">
      <div class="lightbox-backdrop"></div>
      <div class="lightbox-content">
        <button class="lightbox-close" aria-label="Cerrar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        {gallery.length > 1 && (
          <>
            <button class="lightbox-nav lightbox-prev" aria-label="Anterior">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button class="lightbox-nav lightbox-next" aria-label="Siguiente">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </>
        )}

        <div class="lightbox-counter">
          <span id="lightbox-current">1</span> / <span>{gallery.length}</span>
        </div>

        <div class="lightbox-track">
          {gallery.map((src: string, i: number) => (
            <img
              src={src}
              alt={`${project.data.title} — ${i + 1}`}
              class="lightbox-img"
              data-index={i}
              style={i === 0 ? '' : 'display:none'}
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </div>
  )}
</Layout>

<style>
  /* ── Gallery Frames ── */
  .gallery-frame {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.04);
    background: rgba(12,12,20,0.6);
    transition: border-color 0.4s, box-shadow 0.4s;
  }

  .gallery-frame:hover {
    border-color: rgba(232, 167, 65, 0.2);
    box-shadow: 0 4px 30px -8px rgba(0,0,0,0.5), 0 0 40px -15px rgba(232, 167, 65, 0.1);
  }

  .gallery-frame img {
    display: block;
    width: 100%;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s;
    opacity: 0.85;
  }

  .gallery-frame:hover img {
    transform: scale(1.02);
    opacity: 1;
  }

  .gallery-number {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(232, 167, 65, 0.6);
    background: rgba(10,10,15,0.7);
    backdrop-filter: blur(8px);
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(255,255,255,0.06);
    z-index: 2;
    pointer-events: none;
  }

  /* ── Gallery Layout ── */
  .gallery-showcase {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gallery-grid {
    display: grid;
    gap: 0.75rem;
  }

  .gallery-grid-1 {
    grid-template-columns: 1fr;
  }

  .gallery-grid-2 {
    grid-template-columns: 1fr 1fr;
  }

  .gallery-grid-3 {
    grid-template-columns: 1fr 1fr;
  }

  .gallery-grid-3 > :last-child {
    grid-column: 1 / -1;
  }

  @media (max-width: 640px) {
    .gallery-grid-2,
    .gallery-grid-3 {
      grid-template-columns: 1fr;
    }

    .gallery-grid-3 > :last-child {
      grid-column: auto;
    }
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }

  .lightbox[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 10, 0.92);
    backdrop-filter: blur(20px);
  }

  .lightbox-content {
    position: relative;
    width: 90vw;
    max-width: 1100px;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-track {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: 0.75rem;
    border: 1px solid rgba(255,255,255,0.06);
    object-fit: contain;
    box-shadow: 0 20px 60px -15px rgba(0,0,0,0.7);
  }

  .lightbox-close {
    position: absolute;
    top: -2.5rem;
    right: 0;
    color: #606070;
    transition: color 0.2s;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0.5rem;
  }

  .lightbox-close:hover {
    color: #fff;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: #505060;
    transition: color 0.2s, background 0.2s;
    cursor: pointer;
    background: rgba(10,10,15,0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .lightbox-nav:hover {
    color: #e8a741;
    border-color: rgba(232, 167, 65, 0.3);
    background: rgba(232, 167, 65, 0.08);
  }

  .lightbox-prev {
    left: -3.5rem;
  }

  .lightbox-next {
    right: -3.5rem;
  }

  .lightbox-counter {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: #404050;
  }

  @media (max-width: 768px) {
    .lightbox-prev {
      left: 0.5rem;
    }

    .lightbox-next {
      right: 0.5rem;
    }

    .lightbox-nav {
      background: rgba(10,10,15,0.8);
    }

    .lightbox-close {
      top: -2rem;
    }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  if (lightbox) {
    const imgs = lightbox.querySelectorAll<HTMLImageElement>('.lightbox-img');
    const counter = document.getElementById('lightbox-current');
    let current = 0;

    function show(index: number) {
      current = (index + imgs.length) % imgs.length;
      imgs.forEach((img, i) => {
        img.style.display = i === current ? '' : 'none';
      });
      if (counter) counter.textContent = String(current + 1);
    }

    function open(index: number) {
      show(index);
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // Open triggers
    document.querySelectorAll<HTMLElement>('[data-gallery-open]').forEach((el) => {
      el.addEventListener('click', () => {
        open(parseInt(el.dataset.galleryOpen || '0', 10));
      });
    });

    // Close
    lightbox.querySelector('.lightbox-backdrop')?.addEventListener('click', close);
    lightbox.querySelector('.lightbox-close')?.addEventListener('click', close);

    // Nav
    lightbox.querySelector('.lightbox-prev')?.addEventListener('click', () => show(current - 1));
    lightbox.querySelector('.lightbox-next')?.addEventListener('click', () => show(current + 1));

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lightbox.getAttribute('aria-hidden') === 'true') return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  }
</script>
